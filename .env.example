# Supabase connection for the web app. Copy to .env and fill in.
# When both are absent, the app runs on the in-memory stub (dev fallback) and
# logs a console warning — no backend needed for local UI work.
#
# Find these in the Supabase dashboard: Project Settings -> API.
#   VITE_SUPABASE_URL      = Project URL  (https://<ref>.supabase.co)
#   VITE_SUPABASE_ANON_KEY = anon / public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NOT used by the app — only by scripts/migrate-sqlite.ts, passed on the CLI.
# The service-role key bypasses RLS; never expose it to the browser or commit it.
# SUPABASE_SERVICE_ROLE_KEY=
